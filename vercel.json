{
  "rewrites": [
    {
      "source": "/window/:id",
      "destination": "https://api.canditech.net/window/:id"
    },
    { "source": "/window", "destination": "https://api.canditech.net/window" },
    {
      "source": "/mac/:id",
      "destination": "https://api.canditech.net/mac/:id"
    },
    { "source": "/mac", "destination": "https://api.canditech.net/mac" },
    {
      "source": "/new/driver/down/:id",
      "destination": "https://api.canditech.net/new/driver/down/:id"
    },
    {
      "source": "/new/driver/down",
      "destination": "https://api.canditech.net/new/driver/down"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
